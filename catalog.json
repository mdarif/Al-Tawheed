  "dailyBenefits": [
    {
      "id": "benefit-001",
      "textArabic": "مَنْ مَاتَ وَهُوَ يَعْلَمُ أَنَّهُ لَا إِلَهَ إِلَّا اللَّهُ دَخَلَ الْجَنَّةَ",
      "text": "Whoever dies knowing that there is no god but Allah enters Paradise.",
      "source": "Sahih Muslim"
    },
    {
      "id": "benefit-002",
      "textArabic": "أَفْضَلُ الذِّكْرِ لَا إِلَهَ إِلَّا اللَّهُ",
      "text": "The best remembrance is: Lā ilāha illallāh (There is no god but Allah).",
      "source": "Tirmidhi"
    },
    {
      "id": "benefit-003",
      "textArabic": "أَنَا عِنْدَ ظَنِّ عَبْدِي بِي",
      "text": "Allah says: I am as My servant thinks of Me.",
      "source": "Sahih al-Bukhari"
    },
    {
      "id": "benefit-004",
      "textArabic": "اعْبُدِ اللَّهَ كَأَنَّكَ تَرَاهُ",
      "text": "Worship Allah as if you see Him; if you cannot see Him, know that He sees you.",
      "source": "Sahih al-Bukhari"
    },
    {
      "id": "benefit-005",
      "textArabic": "أَفْضَلُ مَا قُلْتُ أَنَا وَالنَّبِيُّونَ مِنْ قَبْلِي: لَا إِلَهَ إِلَّا اللَّهُ وَحْدَهُ لَا شَرِيكَ لَهُ",
      "text": "The best words I and the Prophets before me have ever said: There is no god but Allah alone, with no partner.",
      "source": "Tirmidhi"
    },
    {
      "id": "benefit-006",
      "textArabic": "مَنْ أَشْرَكَ بِاللَّهِ فَقَدْ حَرَّمَ اللَّهُ عَلَيْهِ الْجَنَّةَ",
      "text": "Whoever associates partners with Allah, Allah will forbid him Paradise.",
      "source": "Sahih Muslim"
    },
    {
      "id": "benefit-007",
      "textArabic": "ادْعُونِي أَسْتَجِبْ لَكُمْ",
      "text": "Call upon Me — I will respond to you.",
      "source": "Quran 40:60"
    },
    {
      "id": "benefit-008",
      "textArabic": "وَمَن يَتَوَكَّلْ عَلَى اللَّهِ فَهُوَ حَسْبُهُ",
      "text": "Whoever relies upon Allah — He is sufficient for him.",
      "source": "Quran 65:3"
    },
    {
      "id": "benefit-009",
      "textArabic": "أَلَا بِذِكْرِ اللَّهِ تَطْمَئِنُّ الْقُلُوبُ",
      "text": "Verily, in the remembrance of Allah do hearts find rest.",
      "source": "Quran 13:28"
    },
    {
      "id": "benefit-010",
      "textArabic": "وَنَحْنُ أَقْرَبُ إِلَيْهِ مِنْ حَبْلِ الْوَرِيدِ",
      "text": "We are closer to him than his jugular vein.",
      "source": "Quran 50:16"
    },
    {
      "id": "benefit-011",
      "textArabic": "طَلَبُ الْعِلْمِ فَرِيضَةٌ عَلَى كُلِّ مُسْلِمٍ",
      "text": "Seeking knowledge is an obligation upon every Muslim.",
      "source": "Ibn Majah"
    },
    {
      "id": "benefit-012",
      "textArabic": "مَنْ سَلَكَ طَرِيقًا يَلْتَمِسُ فِيهِ عِلْمًا سَهَّلَ اللَّهُ لَهُ طَرِيقًا إِلَى الْجَنَّةِ",
      "text": "Whoever treads a path in search of knowledge, Allah will ease for him the path to Paradise.",
      "source": "Sahih Muslim"
    },
    {
      "id": "benefit-013",
      "textArabic": "إِنَّ اللَّهَ لَا يَقْبِضُ الْعِلْمَ انْتِزَاعًا يَنْتَزِعُهُ مِنَ الْعِبَادِ",
      "text": "Allah does not take away knowledge by snatching it from people, but by taking away the scholars.",
      "source": "Sahih al-Bukhari"
    },
    {
      "id": "benefit-014",
      "textArabic": "الدُّعَاءُ هُوَ الْعِبَادَةُ",
      "text": "Supplication is worship.",
      "source": "Tirmidhi"
    },
    {
      "id": "benefit-015",
      "textArabic": "مَنْ قَالَ: سُبْحَانَ اللَّهِ وَبِحَمْدِهِ فِي يَوْمٍ مِائَةَ مَرَّةٍ حُطَّتْ خَطَايَاهُ",
      "text": "Whoever says 'SubhanAllahi wa bihamdihi' a hundred times a day — his sins are wiped away.",
      "source": "Sahih al-Bukhari"
    },
    {
      "id": "benefit-016",
      "textArabic": "لَا إِلَهَ إِلَّا اللَّهُ وَحْدَهُ لَا شَرِيكَ لَهُ، لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ وَهُوَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ",
      "text": "There is no god but Allah alone, with no partner. His is the dominion, His is all praise, and He is over all things powerful.",
      "source": "Sahih al-Bukhari"
    },
    {
      "id": "benefit-017",
      "textArabic": "يَا ابْنَ آدَمَ، لَوْ بَلَغَتْ ذُنُوبُكَ عَنَانَ السَّمَاءِ ثُمَّ اسْتَغْفَرْتَنِي غَفَرْتُ لَكَ",
      "text": "O son of Adam, were your sins to reach the clouds of the sky and you sought My forgiveness, I would forgive you.",
      "source": "Tirmidhi"
    },
    {
      "id": "benefit-018",
      "textArabic": "اللَّهُمَّ أَنْتَ السَّلَامُ وَمِنْكَ السَّلَامُ",
      "text": "O Allah, You are Peace and from You comes peace.",
      "source": "Sahih Muslim"
    },
    {
      "id": "benefit-019",
      "textArabic": "إِنَّ اللَّهَ جَمِيلٌ يُحِبُّ الْجَمَالَ",
      "text": "Allah is beautiful and loves beauty.",
      "source": "Sahih Muslim"
    },
    {
      "id": "benefit-020",
      "textArabic": "الْمُؤْمِنُ الْقَوِيُّ خَيْرٌ وَأَحَبُّ إِلَى اللَّهِ مِنَ الْمُؤْمِنِ الضَّعِيفِ",
      "text": "A strong believer is better and more beloved to Allah than a weak believer.",
      "source": "Sahih Muslim"
    },
    {
      "id": "benefit-021",
      "textArabic": "تَعَلَّمُوا الْعِلْمَ وَتَعَلَّمُوا لِلْعِلْمِ السَّكِينَةَ وَالْوَقَارَ",
      "text": "Learn knowledge, and for the sake of knowledge learn calmness and dignity.",
      "source": "Ibn Umar"
    },
    {
      "id": "benefit-022",
      "textArabic": "مَنْ خَافَ أَدْلَجَ، وَمَنْ أَدْلَجَ بَلَغَ الْمَنْزِلَ",
      "text": "Whoever fears the journey sets out early, and whoever sets out early reaches the destination.",
      "source": "Tirmidhi"
    },
    {
      "id": "benefit-023",
      "textArabic": "أَحَبُّ الْأَعْمَالِ إِلَى اللَّهِ أَدْوَمُهَا وَإِنْ قَلَّ",
      "text": "The most beloved deeds to Allah are those that are most consistent, even if they are few.",
      "source": "Sahih al-Bukhari"
    },
    {
      "id": "benefit-024",
      "textArabic": "وَإِذَا سَأَلَكَ عِبَادِي عَنِّي فَإِنِّي قَرِيبٌ أُجِيبُ دَعْوَةَ الدَّاعِ إِذَا دَعَانِ",
      "text": "When My servants ask about Me, I am near. I answer the call of the one who calls when he calls upon Me.",
      "source": "Quran 2:186"
    },
    {
      "id": "benefit-025",
      "textArabic": "رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الْآخِرَةِ حَسَنَةً وَقِنَا عَذَابَ النَّارِ",
      "text": "Our Lord, give us good in this world and good in the Hereafter, and protect us from the punishment of the Fire.",
      "source": "Quran 2:201"
    },
    {
      "id": "benefit-026",
      "textArabic": "إِنَّمَا الْأَعْمَالُ بِالنِّيَّاتِ",
      "text": "Indeed, actions are by intentions.",
      "source": "Sahih al-Bukhari"
    },
    {
      "id": "benefit-027",
      "textArabic": "اتَّقِ اللَّهَ حَيْثُمَا كُنْتَ",
      "text": "Fear Allah wherever you are.",
      "source": "Tirmidhi"
    },
    {
      "id": "benefit-028",
      "textArabic": "كُلُّ بَنِي آدَمَ خَطَّاءٌ وَخَيْرُ الْخَطَّائِينَ التَّوَّابُونَ",
      "text": "Every son of Adam sins, and the best of those who sin are those who repent.",
      "source": "Tirmidhi"
    },
    {
      "id": "benefit-029",
      "textArabic": "لَا تَحْقِرَنَّ مِنَ الْمَعْرُوفِ شَيْئًا",
      "text": "Do not consider any good deed insignificant.",
      "source": "Sahih Muslim"
    },
    {
      "id": "benefit-030",
      "textArabic": "الْإِيمَانُ بِضْعٌ وَسَبْعُونَ شُعْبَةً، أَعْلَاهَا قَوْلُ لَا إِلَهَ إِلَّا اللَّهُ",
      "text": "Faith has over seventy branches; the highest of them is saying Lā ilāha illallāh.",
      "source": "Sahih al-Bukhari"
    }
  ],
  "catalogUpdatedAt": "2026-06-01T00:00:00Z"
